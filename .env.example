LIVEKIT_URL=<your LiveKit server URL>
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>

# ─── Vertex AI mode (recommended; works in HK / regions blocked from aistudio) ───
# Used by anthropic.LLM (Claude Opus 4.7) AND by GeminiSTT / GeminiTTS.
# The VM must run with ADC (gcloud auth application-default login) or
# GOOGLE_APPLICATION_CREDENTIALS pointing to an SA key with `roles/aiplatform.user`.
ANTHROPIC_VERTEX_PROJECT_ID=<your GCP project id>
ANTHROPIC_VERTEX_REGION=global         # claude-opus-4-7 GA on `global`; APAC region not yet
GOOGLE_GENAI_USE_VERTEXAI=true         # tells GeminiSTT/GeminiTTS to use Vertex, not aistudio
GOOGLE_CLOUD_PROJECT=<your GCP project id>
GOOGLE_CLOUD_LOCATION=global           # gemini-3-flash / 3.1-flash-tts preview only on `global`

# ─── Optional model overrides ───
# CLAUDE_MODEL=claude-opus-4-7
# STT_MODEL=gemini-3-flash-preview
# TTS_MODEL=gemini-3.1-flash-tts-preview
# TTS_VOICE=Charon                     # alternatives: Puck, Kore, Aoede, Fenrir, ...

# ─── aistudio mode (alternative; will fail in HK with `1007 region blocked`) ───
# Unset GOOGLE_GENAI_USE_VERTEXAI and set this instead:
# GEMINI_API_KEY=<your Gemini API key from https://aistudio.google.com/apikey>
