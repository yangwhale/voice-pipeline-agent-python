LIVEKIT_URL=<your LiveKit server URL>
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>

# Required for the Gemini-powered Cascade pipeline (LLM + TTS via Gemini API)
GEMINI_API_KEY=<your Gemini API key from https://aistudio.google.com/apikey>

# Required for Cloud Speech (Chirp 2 STT). Path to a GCP service-account JSON
# with `roles/speech.user` (or use ADC).
GOOGLE_APPLICATION_CREDENTIALS=<path to GCP SA key JSON>
GCP_PROJECT=<your GCP project id>
